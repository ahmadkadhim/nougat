# Public endpoint your browser extension and iOS shortcut call.
INBOX_API_URL=https://your-convex-deployment.convex.site

# Convex dev values copied from `.env.local` after `npx convex dev`.
CONVEX_URL=https://your-convex-deployment.convex.cloud
CONVEX_SITE_URL=https://your-convex-deployment.convex.site

# Frontend origin for TanStack Start and Better Auth.
APP_ORIGIN=http://localhost:3000
VITE_APP_ORIGIN=http://localhost:3000
VITE_CONVEX_URL=https://your-convex-deployment.convex.cloud

# X API bearer token for enriching x.com/twitter.com posts.
X_BEARER_TOKEN=your_x_bearer_token

# X app OAuth config for the hosted X connect flow.
X_OAUTH_CLIENT_ID=your_x_oauth_client_id
X_OAUTH_CLIENT_SECRET=your_x_oauth_client_secret

# Better Auth app secret.
BETTER_AUTH_SECRET=generate_a_random_secret

# Optional operator key for privileged operator endpoints.
OPERATOR_API_KEY=replace_me
